DJANGO_SECRET_KEY=replace-this-with-a-local-development-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production-only security settings. Keep the secure defaults unless TLS is
# terminated differently by your deployment proxy.
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_TRUST_PROXY_HEADERS=True

DB_NAME=stockflow
DB_USER=stockflow
DB_PASSWORD=replace-this-with-a-local-password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=UTC

# Docker Compose overrides DB_HOST with `db` and the Redis host with `redis`.
# The values above remain suitable for services running directly on the host.

# Optional demo credentials used by `py -3 manage.py seed_data`.
# Leave blank to create users with unusable passwords.
STOCKFLOW_DEMO_MANAGER_PASSWORD=
STOCKFLOW_DEMO_STAFF_PASSWORD=
